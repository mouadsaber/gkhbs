# Order email (destination)
ORDER_EMAIL=contact@gkhbs.com

# SMTP config for Nodemailer (/api/order)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional: From address (defaults to SMTP_USER)
SMTP_FROM=

# Meta Pixel
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=2376048099583195

# Optional: Facebook Conversions API (server-side events)
FACEBOOK_CAPI_ACCESS_TOKEN=

# Hostinger MySQL (optional; enables DB storage for orders)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Local dev only: set to 1 to print DB_PASSWORD in logs (never enable in production)
LOG_DB_PASSWORD=0
